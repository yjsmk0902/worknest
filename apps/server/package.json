    "@fastify/swagger-ui": "^5.2.1",
    "@fastify/websocket": "^11.0.1",
    "@worknest/db": "workspace:*",
    "@worknest/shared": "workspace:*",
    "better-auth": "^1.1.14",
    "bullmq": "^5.34.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
