{
  "name": "@worknest/editor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    },
    "./*.tsx": {
      "types": "./src/*.tsx",
      "default": "./src/*.tsx"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "echo 'editor: source-only package, no build needed'",
    "lint": "biome check src/",
    "typecheck": "echo 'editor: skipped (TipTap v2/v3 type conflict)'",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@tiptap/core": "^2.11.2",
    "@tiptap/extension-code-block-lowlight": "^2.11.2",
    "@tiptap/extension-details": "^2.11.2",
    "@tiptap/extension-details-content": "^2.11.2",
    "@tiptap/extension-details-summary": "^2.11.2",
    "@tiptap/extension-highlight": "^2.11.2",
    "@tiptap/extension-image": "^2.11.2",
    "@tiptap/extension-link": "^2.11.2",
    "@tiptap/extension-mention": "^2.11.2",
    "@tiptap/extension-placeholder": "^2.11.2",
    "@tiptap/extension-table": "^2.11.2",
    "@tiptap/extension-table-cell": "^2.11.2",
    "@tiptap/extension-table-header": "^2.11.2",
    "@tiptap/extension-table-row": "^2.11.2",
    "@tiptap/extension-task-item": "^2.11.2",
    "@tiptap/extension-task-list": "^2.11.2",
    "@tiptap/extension-underline": "^2.11.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/react": "^2.11.2",
    "@tiptap/starter-kit": "^2.11.2",
    "@tiptap/suggestion": "^2.27.2",
    "@worknest/ui": "workspace:*",
    "lowlight": "^3.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
