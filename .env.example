# ============================================
# Worknest — Environment Variables
# ============================================
# Copy this file to .env and update values as needed.
# Do NOT commit .env to version control.

# --- PostgreSQL ---
POSTGRES_USER=worknest
POSTGRES_PASSWORD=worknest
POSTGRES_DB=worknest
POSTGRES_PORT=5433
DATABASE_URL=postgresql://worknest:worknest@localhost:5433/worknest

# --- Redis ---
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# --- Mailpit (dev email) ---
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
SMTP_HOST=localhost
SMTP_PORT=1025

# --- MinIO (S3-compatible storage, optional) ---
MINIO_ROOT_USER=worknest
MINIO_ROOT_PASSWORD=worknest123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=worknest
S3_SECRET_KEY=worknest123
S3_BUCKET=worknest

# --- Server ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:3000

# --- Web ---
VITE_API_URL=http://localhost:3000

# ============================================
# Production-only (docker-compose.prod.yml)
# ============================================
# Uncomment and configure these for production deployments.

# --- Caddy reverse proxy ---
# DOMAIN=worknest.example.com

# --- SMTP (production email) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=noreply@example.com

# --- Server (production overrides) ---
# NODE_ENV=production
# PORT=4000
# LOG_LEVEL=info
# BETTER_AUTH_SECRET=<generate-a-strong-random-secret>
# BETTER_AUTH_URL=https://worknest.example.com
# CORS_ORIGIN=https://worknest.example.com

# --- PostgreSQL (production) ---
# POSTGRES_PASSWORD=<strong-random-password>
# DATABASE_URL is auto-constructed in docker-compose.prod.yml

# --- MinIO (production) ---
# MINIO_ROOT_PASSWORD=<strong-random-password>
# S3_SECRET_KEY=<same-as-minio-root-password>
