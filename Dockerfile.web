# =============================================================================
# Dockerfile.web — Worknest Web SPA (multi-stage build)
# =============================================================================
# Build context: monorepo root
# Usage:
#   docker build -f Dockerfile.web -t worknest-web .
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: deps — install all dependencies
# ---------------------------------------------------------------------------
FROM node:20-alpine AS deps

RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

WORKDIR /app

# Copy workspace configuration and lockfile first for layer caching
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json turbo.json ./
COPY apps/web/package.json apps/web/
COPY packages/shared/package.json packages/shared/
COPY packages/ui/package.json packages/ui/
COPY packages/editor/package.json packages/editor/

# Install all dependencies (including devDependencies for build stage)
RUN pnpm install --frozen-lockfile

# ---------------------------------------------------------------------------
# Stage 2: build — compile via Turborepo (Vite production build)
# ---------------------------------------------------------------------------
FROM node:20-alpine AS build

RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

WORKDIR /app

# Copy node_modules from deps stage
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules
COPY --from=deps /app/packages/ui/node_modules ./packages/ui/node_modules
COPY --from=deps /app/packages/editor/node_modules ./packages/editor/node_modules

# Copy full source
COPY . .

# Build the web app and its dependencies
RUN pnpm turbo run build --filter=@worknest/web...

# ---------------------------------------------------------------------------
# Stage 3: runtime — nginx serving static files
# ---------------------------------------------------------------------------
FROM nginx:1.27-alpine AS runtime

# Install wget for healthcheck
RUN apk add --no-cache wget

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Copy custom nginx config for SPA
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy Vite build output
COPY --from=build /app/apps/web/dist /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:80/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
